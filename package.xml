<?xml version="1.0"?>
<package format="3">
  <name>llm</name>
  <version>0.1.0</version>
  <description>Large language model inference and chat (ONNX or remote API via libcurl)</description>
  <system_depend check="pkg-config --exists libcurl">libcurl4-openssl-dev</system_depend>
  <system_depend>nlohmann-json3-dev</system_depend>
  <system_depend>llama.cpp-tools-spacemit</system_depend>

  <export>
    <build_type>cmake</build_type>
  </export>
</package>
